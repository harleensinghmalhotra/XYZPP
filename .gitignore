# Dependencies
node_modules/

# Build output (Vercel rebuilds it)
dist/

# Sanity Studio — secrets & build artifacts (studio/ is its own package)
studio/.env
studio/.env.*
studio/dist/
studio/.sanity/
.sanity/

# Local environment — the Vite Sanity read token lives here. Never commit.
.env.local
.env.*.local

# Never commit a plaintext token/secret file
*API Key*.txt
*api key*.txt

# Editor / tooling
.claude/
.agents/

# Local, non-shipping working material (backups, scratch, source dumps)
_archive/

# Root-level image scratch (screenshots). Real bundler assets under src/assets and
# the client-swap deliverable tree under public/site-assets must always ship.
*.png
!src/assets/**
!public/site-assets/**
