# Dependencies
node_modules/

# Sanity studio — secrets & build/runtime artifacts (studio/ is its own package)
studio/.env
studio/.env.*
studio/dist/
studio/.sanity/
.sanity/
# Never commit a plaintext token file (the token belongs only in studio/.env)
*API Key*.txt
*api key*.txt

# Exceeds GitHub 100MB file limit
ALTERNATIVINC.COM Walkthrough.mp4

# Ekta asset handoff kit — local delivery folder, not part of the app
EKTA-HANDOFF/

# Build output — Vercel rebuilds it; committing it only causes churn
dist/

# Screenshot / recon scratch (~1.7 GB)
shots/
recon/

# Root-level screenshots (temporary verification artifacts)
*.png
# ...but src/assets media are real bundler assets that must ship (Vercel imports them)
!src/assets/**

# Local asset-handoff & scratch folders (not part of the app)
FLOW assets/
Ektas Vibe Coded Latest/
sound/

# Dev/scratch scripts
scripts/_*.mjs
scripts/task*-verify.mjs
scripts/task*-*.mjs
calibrate.mjs
build_out.txt

# Source asset folders (Ekta's handoff, not part of the app build)
FRESH EKTA FEEDBACK*/
assets/drive-download-*/
